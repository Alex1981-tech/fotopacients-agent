{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "FotoPacients Agent",
  "version": "0.1.12",
  "identifier": "app.vidnova.fotopacients-agent",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "FotoPacients Agent",
        "label": "main",
        "width": 1100,
        "height": 760,
        "minWidth": 720,
        "minHeight": 540,
        "resizable": true,
        "center": true,
        "decorations": true,
        "dragDropEnabled": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/Alex1981-tech/fotopacients-agent/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQzMTk4ODZFQjEwMUJFMEQKUldRTnZnR3hib2daMDFVTXQvSnY4U3ExRk1VWHd3RWlPZXZsNWNReG9mTDhackNSTHdMT25HOEwK",
      "windows": { "installMode": "passive" }
    }
  }
}
